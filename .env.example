# ==============================================================================
# Conversational SHL Assessment Recommender - Environment Configuration Template
# Copy this file to .env and configure the values.
# ==============================================================================

# FastAPI Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# AI Provider Configurations
# Supported providers: "gemini" or "openai"
LLM_PROVIDER=gemini

# API Keys (Replace with your actual keys in .env)
# Gemini API Key (Required if LLM_PROVIDER is "gemini")
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Required if LLM_PROVIDER is "openai")
OPENAI_API_KEY=your_openai_api_key_here

# Embedding Configuration
# Supported types: "gemini" or "local"
# "gemini" uses Gemini embeddings (recommended, fast, low memory)
# "local" uses sentence-transformers/all-MiniLM-L6-v2 (runs offline, requires PyTorch)
EMBEDDING_TYPE=gemini

# Model Names
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# Confidence Score Threshold (0.0 to 1.0)
# Minimum similarity score required to include a recommendation
CONFIDENCE_THRESHOLD=0.5
